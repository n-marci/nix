{ config, lib, pkgs, ... }:

let
  cfg = config.marci.hosts.vm;
  inherit (lib) mkEnableOption mkIf;
in
{

  ##############################################################################
  # OPTIONS
  ##############################################################################

  options.marci.hosts.vm = {
    enable = mkEnableOption "Enable configuration for vm host";
  };
  
  ##############################################################################
  # CONFIG
  ##############################################################################

  config = mkIf (cfg.enable) {

    ##############################################################################
    # BOOT
    ##############################################################################

    boot.isContainer = true;
  };
}
