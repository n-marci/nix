{ pkgs, ... }:

{
  ##############################################################################
  # BOOT
  ##############################################################################
  
  boot = {
    kernelParams = [
      #########################################
      # Energy savings maybe?
      #########################################
      "mem_sleep_default=deep" 
      "pcie_aspm.policy=powersupersave" 
    ];
  };

  ##############################################################################
  # MOBILE CONFIG
  ##############################################################################
  
  hardware.sensor.iio.enable = true;
  environment.systemPackages = with pkgs; [
    gnome-power-manager
  ];
}
